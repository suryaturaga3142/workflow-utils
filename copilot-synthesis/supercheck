#!/bin/tcsh

# Surya Turaga
# suryapratheek.turaga@gmail.com
# GitHub: suryaturaga3142

# Don't go around poking at random stuff here unless yk what you're doing!
# Just kidding. Mess with the command timeouts, flag defaults, runtime
# files, etc if you want. Important commands are marked with timeouts so
# if you need to change them, yk where to look.
# 
# Note: This script can run FPGA verification remotely from the right server.
# With great power comes great responsibility.

# Configuration Settings

# Command timeouts
set ASM_TIME   = 30
set SIM_TIME   = 60
set SYN_TIME   = 1200
set FPGA_TIME  = 1200
# Run control flags
set DO_SYNTH   = 0
set DO_FPGA    = 0
set CLEAN      = 1
set HALT       = 0
set ASM_TRACE  = 0
set SIM_TRACE  = 0
# Runtime fileset
set LOCKFILE   = ".supercheck.lock"
set EVENT_LOG  = run.events.txt
set STATUS_LOG = status.txt
set DIFF_LOG   = diffs.txt
set ASM_TR_LOG = trace.asm.txt
set ASM_C0_LOG = trace.core0.txt
set ASM_C1_LOG = trace.core1.txt
set SIM_TR_LOG = trace.sim.txt
set RPT_DIR    = my-rpts
set FPGA_DIR   = my-fpga-rpts
# Environment details
set MEM_HEX    = memcpu.hex
set FPGA_HEX   = memfpga.hex
set SRC_DIR    = source

# Argument parsing

# Filter variables
set BUILD_LIST = 0
set FILT_LIST  = ()
set FILT_SING  = ""
set SIM_FLAGS  = ""
# Run settings parsing
foreach arg ( $argv )
    if ( "$arg" == "-synth" ) then
        set DO_SYNTH = 1
        set DO_FPGA = 0
        set BUILD_LIST = 0
    else if ( "$arg" == "-fpga" ) then
        set DO_FPGA = 1
        set DO_SYNTH = 0
        set BUILD_LIST = 0
    else if ( "$arg" == "-caches" ) then
        set SIM_FLAGS = "-c"
        set BUILD_LIST = 0
    else if ( "$arg" == "-mcore" ) then
        set SIM_FLAGS = "-m"
        set BUILD_LIST = 0
    else if ( "$arg" == "-fast" ) then
        set CLEAN = 0
        set BUILD_LIST = 0
    else if ( "$arg" == "-halt" ) then
        set HALT = 1
        set BUILD_LIST = 0
    else if ( "$arg" == "-asmtrace" ) then
        set ASM_TRACE = 1
        set BUILD_LIST = 0
    else if ( "$arg" == "-simtrace" ) then
        set SIM_TRACE = 1
        set BUILD_LIST = 0
    else if ( "$arg" == "-h" ) then
        echo "Usage:"
        echo "  supercheck -l <patterns...> [design] [mode] [flag...]"
        echo ""
        echo "Designs:"
        echo "  -caches     : Simulate with caches"
        echo "  -mcore      : Simulate with multicore"
        echo "  <none>      : Unicore w/o caches"
        echo ""
        echo "Modes:"
        echo "  -synth      : Synthesis"
        echo "  -fpga       : FPGA Test"
        echo "  <none>      : RTL"
        echo ""
        echo "Flags:"
        echo "  -h          : You're seeing it."
        echo "  -fast       : Minimum cleaning in RTL/synth"
        echo "                Use ONLY if yk what you're doing!"
        echo "  -halt       : Halt execution at first failure"
        echo "  -asmtrace   : Trace first test case fail assembly file"
        echo "  -simtrace   : Trace first test case fail simulation"
        echo ""
        exit 0
    else if ( "$arg" == "-l" ) then
        set BUILD_LIST = 1
    else
        if ( $BUILD_LIST ) then
            set FILT_LIST = ( $FILT_LIST "$arg" )
        else
            set FILT_SING = "$arg"
        endif
    endif
end

# Multiple run protection
if ( -e $LOCKFILE ) then
    echo "Error: $LOCKFILE found."
    echo "Kill the existing process before starting another."
    echo "Lock Details:"
    cat $LOCKFILE
    exit 1
endif

# Lockfile creation
echo -n ""                          >! $LOCKFILE
echo "user  :   $USER"              >> $LOCKFILE
echo "host  :   `hostname`"         >> $LOCKFILE
echo "pid   :   $$"                 >> $LOCKFILE
echo "start :   `date`"             >> $LOCKFILE
echo "pwd   :   `pwd`"              >> $LOCKFILE
echo "cmd   :   supercheck $argv"   >> $LOCKFILE

# Earliest point of lockfile ownership
onintr cleanup

# File filtering
if ( $#FILT_LIST > 0 ) then
    set ASM_GLOB = ()
    foreach f ( $FILT_LIST )
        set ASM_GLOB = ( $ASM_GLOB asmFiles/${f}* )
    end
else if ( "$FILT_SING" != "" ) then
    set ASM_GLOB = ( asmFiles/${FILT_SING}* )
else
    set ASM_GLOB = ( asmFiles/*.asm )
endif

if ( $DO_FPGA ) then
    set RPT_DIR = $FPGA_DIR
    set MEM_HEX = $FPGA_HEX
endif

# Run vars
set START_TS = `date +%s`
set RPT_TS = `date +%m-%d-%H-%M`
set CUR_DIR = `pwd`

# FPGA Device Check
if ( $DO_FPGA ) then
    set HOST = `hostname`
    if ( "$HOST" !~ "potr176*" ) then
        echo "ERROR: FPGA Flow only allowed on potr176lnx<NN>.ecn.purdue.edu machines."
        echo "Current host: $HOST"
        echo -n "" >! $EVENT_LOG
        echo "EVT_VERSION=1" >> $EVENT_LOG
        sleep 1
        set ts0 = `date +%s`
        echo "TS=$START_TS EVT=RUN_END ASM=NONE STAGE=HOST STATUS=BLOCK DUR_S=0" >> $EVENT_LOG
        rm -f $LOCKFILE >& /dev/null
        exit 1
    endif
endif

# Setup

# Pre-run cleaning
if ( $CLEAN || $DO_FPGA ) then
    make clean >& /dev/null
endif
if ( $DO_SYNTH || $DO_FPGA ) then
    mkdir -p $RPT_DIR
    if ( $DO_FPGA ) then
        rm -rf $RPT_DIR/* >& /dev/null
    endif
endif

# Runtime file setup
echo -n "" >! $STATUS_LOG
echo -n "" >! $DIFF_LOG
echo -n "" >! $EVENT_LOG
echo -n "" >! $ASM_TR_LOG
echo -n "" >! $ASM_C0_LOG
echo -n "" >! $ASM_C1_LOG
echo -n "" >! $SIM_TR_LOG

sleep 1

# Start event logs
set lat = `grep -P -o '(?<=LAT =)\s*\d+(?=;)' ${CUR_DIR}/${SRC_DIR}/ram.sv`
set ts0 = `date +%s`
echo "EVT_VERSION=1" >> $EVENT_LOG
echo "TS=$START_TS EVT=RUN_START ASM=ALL LAT=$lat" >> $EVENT_LOG
if ( $DO_FPGA) then
    echo "TS=$START_TS EVT=FPGA_INFO ASM=NONE HOSTNAME=`hostname`" >> $EVENT_LOG
endif
# Save calling info
echo "user  :   $USER"              >> $STATUS_LOG
echo "host  :   `hostname`"         >> $STATUS_LOG
echo "pid   :   $$"                 >> $STATUS_LOG
echo "start :   `date`"             >> $STATUS_LOG
echo "pwd   :   `pwd`"              >> $STATUS_LOG
echo "cmd   :   supercheck $argv"   >> $STATUS_LOG
echo "" >> $STATUS_LOG

# Loop control variables
set fail_count = 0
set asm_count  = 0
set synth_done = 0
set trace_done = 0
set exit_code  = 0

# Main loop
foreach file ( $ASM_GLOB )

    if ( ! -e "$file" ) continue

    sleep 1

    if ( $HALT == 1 && $fail_count != 0 ) then
        set END_TS = `date +%s`
        echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=RUN STATUS=HALT TOTAL_ASM=$asm_count FAIL_COUNT=$fail_count" >> $EVENT_LOG
        echo "Done! Failed and halted. Check diffs.txt and build files." >> $STATUS_LOG
        echo "Done!"
        rm -f $LOCKFILE >& /dev/null
        exit 0
    endif

    @ asm_count++
    set filename = `basename "$file"`

    echo "================================" >> $STATUS_LOG
    echo "$filename" >> $STATUS_LOG
    echo "================================" >> $STATUS_LOG

    # ASM simulation
    set ts0 = `date +%s`
    echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=ASM STATUS=START" >> $EVENT_LOG
    echo "> Simulating assembly file $filename ..." >> $STATUS_LOG

    asm "$file"
    timeout $ASM_TIME sim $SIM_FLAGS -t >&! /tmp/asm_trace_${filename}_${USER}.tmp
    set exit_code = $status
    if ( $ASM_TRACE == 1 && $trace_done == 0 ) then
        echo "ASM: ${filename}\n" >! $ASM_TR_LOG
        echo "ASM: ${filename}\n" >! $ASM_C0_LOG
        echo "ASM: ${filename}\n" >! $ASM_C1_LOG
        cat /tmp/asm_trace_${filename}_${USER}.tmp | tail -n 100 >> $ASM_TR_LOG
        cat /tmp/asm_trace_${filename}_${USER}.tmp | grep "(Core 0)" | head -n 100 >> $ASM_C0_LOG
        cat /tmp/asm_trace_${filename}_${USER}.tmp | grep "(Core 1)" | head -n 100 >> $ASM_C1_LOG
        echo "" >> $ASM_TR_LOG
        echo "" >> $ASM_C0_LOG
        echo "" >> $ASM_C1_LOG
    endif
    if ( $exit_code != 0 ) then
        if ( $exit_code == 124 ) then
            echo "> ASM Simulation Timeout." >> $STATUS_LOG
        else
            echo "> ASM Simulation Failure." >> $STATUS_LOG
        endif
        echo "" >> $STATUS_LOG
        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        if ( $exit_code == 124 ) then
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
        else
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=FAIL CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
        endif
        @ fail_count++
        @ synth_done = 0
        @ trace_done = 1
        @ exit_code = 0
        if ( $HALT == 0 ) make clean >& /dev/null
        continue
    endif

    set ts1 = `date +%s`
    @ dur = $ts1 - $ts0
    echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=OK DUR_S=$dur" >> $EVENT_LOG

    # Synthesis (done once if requested)
    if ( $DO_SYNTH && $synth_done == 0 ) then
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=SYNTH STATUS=START" >> $EVENT_LOG
        echo "> Synthesizing design for $filename ..." >> $STATUS_LOG

        set rpt_file = $RPT_DIR/rpt_${RPT_TS}_${filename}.txt

        timeout $SYN_TIME make system.syntp >&! $rpt_file
        set exit_code = $status
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> Project Synthesis Timeout." >> $STATUS_LOG
            else
                echo "> Project Synthesis Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=FAIL CODE=$exit_code DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG
            endif
            @ fail_count++
            @ synth_done = 0
            @ exit_code = 0
            if ( $HALT == 0 ) make clean >& /dev/null
            continue
        endif
        sleep 2
        @ synth_done = 1

        # Synthesis frequency analysis
        cat $rpt_file | grep -P "Fmax:\s+\d+\.\d+" >> $STATUS_LOG
        set main_clk = `grep -P -o '(?<=Fmax:)\s*\d+\.\d+' $rpt_file | head -n 1`
        set cpu_clk  = `grep -P -o '(?<=Fmax:)\s*\d+\.\d+' $rpt_file | tail -n 1`
        set fmax = `echo "if ( $main_clk / 2 < $cpu_clk ) $main_clk / 2 else $cpu_clk" | bc -l`
        set fmax = `printf "%.2f" ${fmax}`

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=OK DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG
        echo "TS=$ts1 EVT=SYNTH_RESULT ASM=$filename MAIN=$main_clk CPU=$cpu_clk FMAX=$fmax" >> $EVENT_LOG
    endif

    # FPGA Testing
    if ( $DO_FPGA ) then
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=FPGA STATUS=START" >> $EVENT_LOG
        echo "> Testing FPGA Implementation for $filename ..." >> $STATUS_LOG

        set rpt_file = $RPT_DIR/rpt_fpga_${RPT_TS}_${filename}.txt

        timeout $FPGA_TIME synthesize_xilinx -m -d -p -t -f 200 system_fpga >&! $rpt_file
        set exit_code = $status
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> FPGA Implementation Timeout." >> $STATUS_LOG
            else
                echo "> FPGA Implementation Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=FAIL CODE=$exit_code DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG
            endif
            @ fail_count++
            @ exit_code = 0
            if ( $HALT == 0 ) make clean >& /dev/null
            continue
        endif
        sleep 5

        # FPGA frequency analysis
        cat $rpt_file | grep -P "Fmax:\s+\d+\.\d+" | head -n 2 >> $STATUS_LOG
        
        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=OK DUR_S=$dur RPT=$rpt_file" >> $EVENT_LOG

    else
        # RTL / Gate Level Simulation
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=SIM STATUS=START" >> $EVENT_LOG
        echo "> Running simulation for $filename ..." >> $STATUS_LOG

        timeout $SIM_TIME make system.sim >&! /tmp/sim_trace_${filename}_${USER}.tmp
        set exit_code = $status
        if ( $SIM_TRACE == 1 && $trace_done == 0 ) then
            echo "ASM: $filename\n" >! $SIM_TR_LOG
            cat /tmp/sim_trace_${filename}_${USER}.tmp | tail -n 500 >> $SIM_TR_LOG
            echo "" >> $SIM_TR_LOG
        endif
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> Simulation Timeout." >> $STATUS_LOG
            else
                echo "> Simulation Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=FAIL CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
            endif
            @ fail_count++
            @ synth_done = 0
            @ trace_done = 1
            @ exit_code = 0
            if ( $HALT == 0 ) make clean >& /dev/null
            continue
        else
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=OK DUR_S=$dur" >> $EVENT_LOG
        endif
        sleep 2

    endif

    # Diff
    set ts0 = `date +%s`
    echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=DIFF STATUS=START" >> $EVENT_LOG

    diff memsim.hex $MEM_HEX >! /tmp/diff_${filename}_${USER}.tmp
    set diff_status = $status

    if ( $diff_status != 0 ) then
        @ fail_count++
        echo "> Noting differences..." >> $STATUS_LOG
        set diff_lines = `wc -l < /tmp/diff_${filename}_${USER}.tmp`

        echo "==========================================" >> $DIFF_LOG
        echo "MISMATCH IN FILE: $filename" >> $DIFF_LOG
        echo "==========================================" >> $DIFF_LOG
        cat /tmp/diff_${filename}_${USER}.tmp >> $DIFF_LOG
        echo "" >> $DIFF_LOG

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=DIFF STATUS=FAIL DUR_S=$dur DIFF_LINES=$diff_lines" >> $EVENT_LOG
    else
        echo "> No differences..." >> $STATUS_LOG

        echo "==========================================" >> $DIFF_LOG
        echo "NO MISMATCH: $filename" >> $DIFF_LOG
        echo "==========================================" >> $DIFF_LOG
        echo "" >> $DIFF_LOG

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=DIFF STATUS=OK DUR_S=$dur" >> $EVENT_LOG
    endif

    echo "" >> $STATUS_LOG
end

# Cleanup

# Needed if clean / FPGA AND not halt / success run
if ( $CLEAN || $DO_FPGA ) then
    if ( $HALT == 0 || $fail_count == 0 ) make clean >& /dev/null
endif

set END_TS = `date +%s`

if ( $fail_count == 0 ) then
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=RUN STATUS=OK TOTAL_ASM=$asm_count" >> $EVENT_LOG
    echo "Done! All tests passed." >> $STATUS_LOG
else
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=RUN STATUS=FAIL TOTAL_ASM=$asm_count FAIL_COUNT=$fail_count" >> $EVENT_LOG
    echo "Done! $fail_count failures detected. Check diffs.txt and build files." >> $STATUS_LOG
endif

echo "Done!"

rm -f $LOCKFILE >& /dev/null
exit 0

cleanup:
    set END_TS = `date +%s`
    echo "[supercheck] Process interrupted."
    echo "\nProcess interrupted." >> $STATUS_LOG
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=INTR STATUS=INTR TOTAL_ASM=$asm_count FAIL_COUNT=$fail_count" >> $EVENT_LOG
    rm -f $LOCKFILE >& /dev/null
    exit 1

