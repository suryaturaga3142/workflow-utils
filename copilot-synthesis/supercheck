#!/bin/tcsh

# Argument parsing
set DO_SYNTH   = 0
set DO_FPGA    = 0
set BUILD_LIST = 0
set FILT_LIST  = ()
set FILT_SING  = ""

set CLEAN = 1
set SIM_FLAGS = ""

# Run settings
foreach arg ( $argv )
    if ( "$arg" == "-synth" ) then
        set DO_SYNTH = 1
        set BUILD_LIST = 0
    else if ( "$arg" == "-fpga" ) then
        set DO_FPGA = 1
        set BUILD_LIST = 0
    else if ( "$arg" == "-caches" ) then
        set SIM_FLAGS = "-c"
        set BUILD_LIST = 0
    else if ( "$arg" == "-mcore" ) then
        set SIM_FLAGS = "-m"
        set BUILD_LIST = 0
    else if ( "$arg" == "-fast" ) then
        set CLEAN = 0
        set BUILD_LIST = 0
    else if ( "$arg" == "-h" ) then
        echo "Usage:"
        echo "  supercheck -l <patterns> [mode] [flags]"
        echo ""
        echo "Modes:"
        echo "  -synth  : Synthesis"
        echo "  -fpga   : FPGA Test"
        echo "  -h      : You're seeing it."
        echo ""
        echo "Flags:"
        echo "  -caches : Simulate with caches"
        echo "  -mcore  : Simulate with multicore"
        echo "  -fast   : No intermediate cleaning in RTL/synth"
        echo "            Use ONLY if yk what you're doing!"
        exit 0
    else if ( "$arg" == "-l" ) then
        set BUILD_LIST = 1
    else
        if ( $BUILD_LIST ) then
            set FILT_LIST = ( $FILT_LIST "$arg" )
        else
            set FILT_SING = "$arg"
        endif
    endif
end

# Multiple run protection
set LOCKFILE = ".supercheck.lock"
if ( -e $LOCKFILE ) then
    echo "Error: $LOCKFILE found."
    echo "Kill the existing process before starting another."
    echo "Lock Details:"
    cat $LOCKFILE
    exit 1
endif

# Lockfile creation
echo -n "" >! $LOCKFILE
echo "user  :   $USER" >> $LOCKFILE
echo "host  :   `hostname`" >> $LOCKFILE
echo "pid   :   $$" >> $LOCKFILE
echo "start :   `date`" >> $LOCKFILE
echo "cwd   :   `pwd`" >> $LOCKFILE
echo "cmd   :   supercheck $argv" >> $LOCKFILE

# Earliest point of lockfile ownership
onintr cleanup

if ( $#FILT_LIST > 0 ) then
    set ASM_GLOB = ()
    foreach f ( $FILT_LIST )
        set ASM_GLOB = ( $ASM_GLOB asmFiles/${f}* )
    end
else if ( "$FILT_SING" != "" ) then
    set ASM_GLOB = ( asmFiles/${FILT_SING}* )
else
    set ASM_GLOB = ( asmFiles/*.asm )
endif

# Configuration
set EVENT_LOG  = run.events.txt
set STATUS_LOG = status.txt
set DIFF_LOG   = diffs.txt
set RPT_DIR    = my-rpts
set MEM_HEX    = memcpu.hex

if ( $DO_FPGA ) then
    set DO_SYNTH = 0
    set RPT_DIR = my-fpga-rpts
    set MEM_HEX = memfpga.hex
endif

set START_TS = `date +%s`

# Init

if ( $DO_FPGA ) then
    set HOST = `hostname`
    if ( "$HOST" !~ "potr176*" ) then
        echo "ERROR: FPGA Flow only allowed on potr176lnx<NN>.ecn.purdue.edu machines."
        echo "Current host: $HOST"

        echo -n "" >! $EVENT_LOG
        echo "EVT_VERSION=1" >> $EVENT_LOG
        set ts0 = `date +%s`
        echo "TS=$START_TS EVT=RUN_END ASM=NONE STAGE=HOST STATUS=FAIL DUR_S=0" >> $EVENT_LOG

        rm -f $LOCKFILE >& /dev/null
        exit 1
    endif
endif

# Setup

if ( $CLEAN || $DO_FPGA ) then
    make clean >& /dev/null
endif

if ( $DO_SYNTH || $DO_FPGA ) then
    mkdir -p $RPT_DIR
    if ( $DO_FPGA ) then
        rm -rf $RPT_DIR/* >& /dev/null
    endif
endif

echo -n "" >! $STATUS_LOG
echo -n "" >! $DIFF_LOG
echo -n "" >! $EVENT_LOG

set ts0 = `date +%s`
echo "EVT_VERSION=1" >> $EVENT_LOG
echo "TS=$START_TS EVT=RUN_START ASM=ALL STAGE=RUN STATUS=START" >> $EVENT_LOG

set fail_count = 0
set asm_count  = 0
set synth_done = 0
set exit_code  = 0

# Main loop
foreach file ( $ASM_GLOB )

    if ( ! -e "$file" ) continue

    sleep 1

    @ asm_count++
    set filename = `basename "$file"`

    echo "================================" >> $STATUS_LOG
    echo "$filename" >> $STATUS_LOG
    echo "================================" >> $STATUS_LOG

    # ASM simulation
    set ts0 = `date +%s`
    echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=ASM STATUS=START" >> $EVENT_LOG
    echo "> Simulating assembly file $file ..." >> $STATUS_LOG

    asm "$file"
    timeout 30 sim $SIM_FLAGS >& /dev/null
    set exit_code = $status
    if ( $exit_code != 0 ) then
        if ( $exit_code == 124 ) then
            echo "> ASM Simulation Timeout." >> $STATUS_LOG
        else
            echo "> ASM Simulation Failure." >> $STATUS_LOG
        endif
        echo "" >> $STATUS_LOG
        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        if ( $exit_code == 124 ) then
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
        else
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=FAIL CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
        endif
        @ fail_count++
        @ synth_done = 0
        @ exit_code = 0
        make clean >& /dev/null
        continue
    endif

    set ts1 = `date +%s`
    @ dur = $ts1 - $ts0
    echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=ASM STATUS=OK DUR_S=$dur" >> $EVENT_LOG

    # Synthesis (done once if cleaned)
    if ( $DO_SYNTH && $synth_done == 0 && $CLEAN ) then
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=SYNTH STATUS=START" >> $EVENT_LOG
        echo "> Synthesizing design for $filename ..." >> $STATUS_LOG

        timeout 1200 make system.syntp >&! $RPT_DIR/rpt_${filename}.txt
        set exit_code = $status
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> Project Synthesis Timeout." >> $STATUS_LOG
            else
                echo "> Project Synthesis Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur RPT=$RPT_DIR/rpt_${filename}.txt" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=FAIL CODE=$exit_code DUR_S=$dur RPT=$RPT_DIR/rpt_${filename}.txt" >> $EVENT_LOG
            endif
            @ fail_count++
            @ synth_done = 0
            @ exit_code = 0
            make clean >& /dev/null
            continue
        endif
        sleep 2
        @ synth_done = 1

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SYNTH STATUS=OK DUR_S=$dur RPT=$RPT_DIR/rpt_${filename}.txt" >> $EVENT_LOG
    endif

    # FPGA Testing
    if ( $DO_FPGA ) then
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=FPGA STATUS=START" >> $EVENT_LOG
        echo "> Testing FPGA Implementation for $filename ..." >> $STATUS_LOG

        timeout 1200 synthesize_xilinx -m -d -p -t -f 200 system_fpga >&! $RPT_DIR/rpt_fpga_${filename}.txt
        set exit_code = $status
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> FPGA Implementation Timeout." >> $STATUS_LOG
            else
                echo "> FPGA Implementation Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur RPT=$RPT_DIR/rpt_fpga_${filename}.txt" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=FAIL CODE=$exit_code DUR_S=$dur RPT=$RPT_DIR/rpt_fpga_${filename}.txt" >> $EVENT_LOG
            endif
            @ fail_count++
            @ exit_code = 0
            make clean >& /dev/null
            continue
        else
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=FPGA STATUS=OK DUR_S=$dur RPT=$RPT_DIR/rpt_fpga_${filename}.txt" >> $EVENT_LOG
        endif
        sleep 5

    else
        # RTL / Gate Level Simulation
        set ts0 = `date +%s`
        echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=SIM STATUS=START" >> $EVENT_LOG
        echo "> Running simulation for $filename ..." >> $STATUS_LOG

        timeout 60 make system.sim >& /dev/null
        set exit_code = $status
        if ( $exit_code != 0 ) then
            if ( $exit_code == 124 ) then
                echo "> Simulation Timeout." >> $STATUS_LOG
            else
                echo "> Simulation Failure." >> $STATUS_LOG
            endif
            echo "" >> $STATUS_LOG
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            if ( $exit_code == 124 ) then
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=TIMEOUT CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
            else
                echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=FAIL CODE=$exit_code DUR_S=$dur" >> $EVENT_LOG
            endif
            @ fail_count++
            @ synth_done = 0
            @ exit_code = 0
            make clean >& /dev/null
            continue
        else
            set ts1 = `date +%s`
            @ dur = $ts1 - $ts0
            echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=SIM STATUS=OK DUR_S=$dur" >> $EVENT_LOG
        endif
        sleep 2

    endif

    # Diff
    set ts0 = `date +%s`
    echo "TS=$ts0 EVT=STAGE_START ASM=$filename STAGE=DIFF STATUS=START" >> $EVENT_LOG
    echo "> Noting differences..." >> $STATUS_LOG

    diff memsim.hex $MEM_HEX >! /tmp/diff_${filename}.tmp
    set diff_status = $status

    if ( $diff_status != 0 ) then
        @ fail_count++

        set diff_lines = `wc -l < /tmp/diff_${filename}.tmp`

        echo "==========================================" >> $DIFF_LOG
        echo "MISMATCH IN FILE: $file" >> $DIFF_LOG
        echo "==========================================" >> $DIFF_LOG
        cat /tmp/diff_${filename}.tmp >> $DIFF_LOG
        echo "" >> $DIFF_LOG

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=DIFF STATUS=FAIL DUR_S=$dur DIFF_LINES=$diff_lines" >> $EVENT_LOG
    else
        echo "==========================================" >> $DIFF_LOG
        echo "NO MISMATCH: $file" >> $DIFF_LOG
        echo "==========================================" >> $DIFF_LOG
        echo "" >> $DIFF_LOG

        set ts1 = `date +%s`
        @ dur = $ts1 - $ts0
        echo "TS=$ts1 EVT=STAGE_END ASM=$filename STAGE=DIFF STATUS=OK DUR_S=$dur" >> $EVENT_LOG
    endif

    echo "" >> $STATUS_LOG
end

# Cleanup

if ( $CLEAN || $DO_FPGA ) then
    make clean >& /dev/null
endif

set END_TS = `date +%s`

if ( $fail_count == 0 ) then
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=RUN STATUS=OK TOTAL_ASM=$asm_count" >> $EVENT_LOG
    echo "Done! All tests passed." >> $STATUS_LOG
else
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=RUN STATUS=FAIL TOTAL_ASM=$asm_count FAIL_COUNT=$fail_count" >> $EVENT_LOG
    echo "Done! $fail_count failures detected. Check diffs.txt and build files." >> $STATUS_LOG
endif

echo "Done!"

rm -f $LOCKFILE >& /dev/null
exit 0

cleanup:
    set END_TS = `date +%s`
    echo "[supercheck] Process interrupted."
    echo "\nProcess interrupted." >> $STATUS_LOG
    echo "TS=$END_TS EVT=RUN_END ASM=ALL STAGE=INTR STATUS=INTR TOTAL_ASM=$asm_count FAIL_COUNT=$fail_count" >> $EVENT_LOG
    rm -f $LOCKFILE >& /dev/null
    exit 1

