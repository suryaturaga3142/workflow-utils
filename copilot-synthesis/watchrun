# Configuration
EVENT_LOG="run.events.txt"

# Check webhook
if [ -z "$DISCORD_SYNTH_WEBHOOK" ]; then
    echo "ERROR: DISCORD_SYNTH_WEBHOOK not set"
    exit 1
fi

# Helper function: send Discord message
send_discord() {
    local msg="$1"
    curl -s -X POST -H "Content-Type: application/json" \
        -d "{\"content\": \"$msg\"}" "$DISCORD_SYNTH_WEBHOOK" >/dev/null
}

# Optional run title
RUN_TITLE="$1"

if [ -n "$RUN_TITLE" ]; then
    send_discord "đź§Ş **System Run Started**\n> **$RUN_TITLE**"
    echo "[watcher] Posted run title: $RUN_TITLE"
fi

echo "[watcher] Watching $EVENT_LOG ..."
echo "[watcher] Will exit on RUN_END"

# State
declare -A seen_failures

# Tail loop
tail -n 0 -F "$EVENT_LOG" | while read -r line; do
    # Ignore version header
    [[ "$line" == EVT_VERSION* ]] && continue

    # Extract key fields
    evt=$(echo "$line" | sed -n 's/.*EVT=\([^ ]*\).*/\1/p')
    asm=$(echo "$line" | sed -n 's/.*ASM=\([^ ]*\).*/\1/p')
    stage=$(echo "$line" | sed -n 's/.*STAGE=\([^ ]*\).*/\1/p')
    stat=$(echo "$line" | sed -n 's/.*STATUS=\([^ ]*\).*/\1/p')
    exit_code=$(echo "$line" | sed -n 's/.*CODE=\([^ ]*\).*/\1/p')

    # Handling different events
    if [ "$evt" == "RUN_END" ]; then
        if [ "$stat" == "OK" ]; then
            msg="âś… **RUN COMPLETE**\n> All assembly files passed."
        elif [ "$stat" == "INTR" ]; then
            msg="đź’Ą **RUN INTERRUPTED**\n> Check \`run.events.txt\` for details."
        elif [ "$stat" == "HALT" ]; then
            msg="đź›‘ **RUN HALTED**\n> Check run files for details."
        elif [ "$stat" == "BLOCK" ]; then
            msg="đźš« **RUN BLOCKED**\n> Crucial setup requirement unmet."
        else
            msg="âš ď¸Ź **RUN COMPLETE WITH FAILURES**\n> Check run files for details."
        fi
        send_discord "$msg"
        echo "[watcher] Run ended. Exiting."
        exit 0
    elif [ "$evt" == "RUN_START" ]; then
        lat=$(echo "$line" | sed -n 's/.*LAT=\([^ ]*\).*/\1/p')
        msg="> LAT = $lat"
        send_discord "$msg"
    elif [ "$evt" == "FPGA_INFO" ]; then
        msg="> Hostname = \`${HOSTNAME}\`"
        send_discord "$msg"
    elif [ "$evt" == "SYNTH_RESULT" ]; then
        main=$(echo "$line" | sed -n 's/.*MAIN=\([^ ]*\).*/\1/p')
        cpu=$(echo "$line" | sed -n 's/.*CPU=\([^ ]*\).*/\1/p')
        fmax=$(echo "$line" | sed -n 's/.*FMAX=\([^ ]*\).*/\1/p')
        msg="âŹ±ď¸Ź **Synthesis Complete**\n> **Fmax = ${fmax} MHz**\n> MAIN: ${main} MHz\n> CPUCLK: ${cpu} MHz"
        send_discord "$msg"
    fi

    # Failure notification
    if [[ "$stat" == "FAIL" || "$stat" == "TIMEOUT" ]]; then
        key="${asm}:${stage}"
        if [ -z "${seen_failures[$key]}" ]; then
            seen_failures[$key]=1
            msg="âťŚ **FAILURE DETECTED**\n> ASM: \`$asm\`\n> Stage: $stage\n> Status: $stat\n> Exit Code: $exit_code"
            send_discord "$msg"
            echo "[watcher] Alerted failure: $asm $stage $stat $exit_code"
        fi
    fi
done

